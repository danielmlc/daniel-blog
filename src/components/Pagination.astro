---
import ArrowLeft from '../icons/ArrowLeft.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import IconButton from './IconButton.astro';

const { page, class: className } = Astro.props;
---

<nav aria-label="Pagination" class:list={['px-12 py-2 relative text-center', className]}>
    {
        page.url.prev && (
            <IconButton
                class="absolute left-0 top-1/2 -translate-y-1/2"
                href={page.url.prev}
                aria-label={`前往第 ${page.currentPage - 1} 页，共 ${page.lastPage} 页`}
            >
                <ArrowLeft class="w-5 h-5 fill-current" />
            </IconButton>
        )
    }
    <span class="text-sm font-serif text-main/60 tracking-wider" aria-current="page">第 {page.currentPage} 页 / 共 {page.lastPage} 页</span>
    {
        page.url.next && (
            <IconButton
                class="absolute right-0 top-1/2 -translate-y-1/2"
                href={page.url.next}
                aria-label={`前往第 ${page.currentPage + 1} 页，共 ${page.lastPage} 页`}
            >
                <ArrowRight class="w-5 h-5 fill-current" />
            </IconButton>
        )
    }
</nav>
