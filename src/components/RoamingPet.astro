---
// RoamingPet.astro - Global roaming cat for all pages
---

<div
    id="rp-root"
    aria-hidden="true"
    style="position:fixed;z-index:9998;left:-120px;top:50%;opacity:0;pointer-events:none;transition:left 2.5s cubic-bezier(.4,0,.2,1),top 2.5s cubic-bezier(.4,0,.2,1),opacity 0.8s ease;user-select:none;"
>
    <!-- Close button (Hide for good) -->
    <div
        id="rp-close"
        style="position:absolute;top:-25px;right:-15px;width:20px;height:20px;background:var(--color-main, currentColor);color:var(--color-bg, #fff);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;opacity:0;pointer-events:none;transition:opacity 0.2s;"
        title="让我静静 (Hide)"
    >
        ✕
    </div>

    <div id="rp-inner" style="pointer-events:auto;cursor:grab;position:relative;" title="摸摸我 / 拖动我~">
        <!-- Speech bubble -->
        <div
            id="rp-speech"
            class="bg-main shadow-sm"
            style="position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);font-size:0.7rem;opacity:0;transition:opacity 0.3s ease;padding:3px 10px;border:1px solid currentColor;border-radius:10px 10px 10px 0;white-space:nowrap;font-style:italic;pointer-events:none;font-family:serif;"
        >
            喵~
        </div>
        <!-- Cat body -->
        <div id="rp-cat" style="position:relative;">
            <!-- Head -->
            <div style="position:relative;width:64px;height:48px;">
                <!-- Left ear -->
                <div
                    style="position:absolute;top:-9px;left:5px;width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:9px solid currentColor;opacity:0.65;transform:rotate(-10deg);"
                >
                </div>
                <!-- Right ear -->
                <div
                    style="position:absolute;top:-9px;right:5px;width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:9px solid currentColor;opacity:0.65;transform:rotate(10deg);"
                >
                </div>
                <!-- Face -->
                <div
                    class="bg-main"
                    style="width:64px;height:48px;border-radius:50%;border:2px solid currentColor;display:flex;align-items:center;justify-content:center;gap:14px;position:relative;"
                >
                    <!-- Left eye -->
                    <div
                        id="rp-eye-l"
                        style="width:8px;height:10px;border-radius:50%;background:currentColor;position:relative;transition:height 0.1s,transform 0.2s;"
                    >
                        <div
                            id="rp-pupil-l"
                            class="bg-main"
                            style="width:4px;height:4px;border-radius:50%;position:absolute;top:2px;left:1px;transition:transform 0.08s linear;"
                        >
                        </div>
                    </div>
                    <!-- Right eye -->
                    <div
                        id="rp-eye-r"
                        style="width:8px;height:10px;border-radius:50%;background:currentColor;position:relative;transition:height 0.1s,transform 0.2s;"
                    >
                        <div
                            id="rp-pupil-r"
                            class="bg-main"
                            style="width:4px;height:4px;border-radius:50%;position:absolute;top:2px;left:1px;transition:transform 0.08s linear;"
                        >
                        </div>
                    </div>
                    <!-- Nose -->
                    <div
                        style="position:absolute;bottom:11px;left:50%;transform:translateX(-50%);width:5px;height:3px;border-radius:50%;background:currentColor;opacity:0.5;"
                    >
                    </div>
                    <!-- Mouth -->
                    <div
                        id="rp-mouth"
                        style="position:absolute;bottom:5px;left:50%;transform:translateX(-50%);width:14px;height:7px;border-bottom:1px solid currentColor;border-radius:0 0 50% 50%;opacity:0.4;transition:all 0.25s ease;"
                    >
                    </div>
                </div>
            </div>
            <!-- Body stub and Tail -->
            <div
                style="position:relative;margin:0 auto;width:36px;height:8px;border-left:2px solid currentColor;border-right:2px solid currentColor;opacity:0.3;border-radius:0 0 8px 8px;"
            >
            </div>
            <!-- Tail -->
            <div
                id="rp-tail"
                style="position:absolute;bottom:4px;right:-18px;width:24px;height:4px;background:currentColor;opacity:0.6;border-radius:2px;transform-origin:left center;transform:rotate(-30deg);animation: rp-tail-wag 3s ease-in-out infinite;"
            >
            </div>
        </div>
    </div>
</div>

<style>
    @keyframes rp-float {
        0%,
        100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-4px);
        }
    }
    @keyframes rp-nod {
        0%,
        100% {
            transform: translateY(0) rotate(0deg);
        }
        20% {
            transform: translateY(-10px) rotate(-6deg);
        }
        40% {
            transform: translateY(2px) rotate(0deg);
        }
        65% {
            transform: translateY(-6px) rotate(4deg);
        }
        80% {
            transform: translateY(0) rotate(0deg);
        }
    }
    @keyframes rp-spin {
        0% {
            transform: rotate(0deg) scale(1);
        }
        50% {
            transform: rotate(180deg) scale(1.1);
        }
        100% {
            transform: rotate(360deg) scale(1);
        }
    }
    @keyframes rp-bounce {
        0%,
        100% {
            transform: translateY(0) scale(1);
        }
        30% {
            transform: translateY(-14px) scale(1.12);
        }
        55% {
            transform: translateY(-6px) scale(1.06);
        }
        75% {
            transform: translateY(-10px) scale(1.09);
        }
    }
    @keyframes rp-wave {
        0%,
        100% {
            transform: rotate(0deg) translateX(0);
        }
        20% {
            transform: rotate(-12deg) translateX(-5px);
        }
        50% {
            transform: rotate(12deg) translateX(5px);
        }
        70% {
            transform: rotate(-8deg) translateX(-3px);
        }
    }
    @keyframes rp-tremble {
        0%,
        100% {
            transform: translateX(0) rotate(0);
        }
        15% {
            transform: translateX(-4px) rotate(-4deg);
        }
        35% {
            transform: translateX(4px) rotate(4deg);
        }
        55% {
            transform: translateX(-3px) rotate(-2deg);
        }
        75% {
            transform: translateX(3px) rotate(2deg);
        }
    }
    @keyframes rp-shy {
        0%,
        100% {
            transform: translateY(0) rotate(0);
        }
        40% {
            transform: translateY(-3px) rotate(-15deg);
        }
        60% {
            transform: translateY(-3px) rotate(-15deg);
        }
    }
    @keyframes rp-tail-wag {
        0%,
        100% {
            transform: rotate(-30deg);
        }
        50% {
            transform: rotate(-10deg);
        }
    }

    #rp-cat.rp-float {
        animation: rp-float 2.8s ease-in-out infinite;
    }
    #rp-cat.rp-nod {
        animation: rp-nod 0.9s ease-in-out;
    }
    #rp-cat.rp-spin {
        animation: rp-spin 0.6s ease-in-out;
    }
    #rp-cat.rp-bounce {
        animation: rp-bounce 0.55s ease-in-out 2;
    }
    #rp-cat.rp-wave {
        animation: rp-wave 0.55s ease-in-out 3;
    }
    #rp-cat.rp-tremble {
        animation: rp-tremble 0.4s ease-in-out 2;
    }
    #rp-cat.rp-shy {
        animation: rp-shy 0.6s ease-in-out 2;
    }

    #rp-root:hover #rp-close {
        opacity: 1;
        pointer-events: auto;
    }
</style>

<script>
    (function () {
        let isVisible = false;
        let interacting = false;
        let isDragging = false;

        let wanderTimer = 0;
        let appearTimer = 0;
        let speechTimer = 0;
        let scrollTimer = 0;
        let lastScrollY = typeof window !== 'undefined' ? window.scrollY : 0;

        // Shared DOM refs
        let root: HTMLElement | null = null;
        let inner: HTMLElement | null = null;
        let cat: HTMLElement | null = null;
        let speech: HTMLElement | null = null;
        let eyeL: HTMLElement | null = null;
        let eyeR: HTMLElement | null = null;
        let pupilL: HTMLElement | null = null;
        let pupilR: HTMLElement | null = null;
        let mouth: HTMLElement | null = null;
        let closeBtn: HTMLElement | null = null;

        // Cleanup function for SPA context
        function cleanupCat() {
            clearTimeout(wanderTimer);
            clearTimeout(appearTimer);
            clearTimeout(speechTimer);
            clearTimeout(scrollTimer);
            document.removeEventListener('mousemove', onMouseMoveHandler);
            document.removeEventListener('scroll', onScrollHandler);
        }

        function initCat() {
            // Check if user has hidden it (saved in localStorage)
            if (localStorage.getItem('rp-hidden') === 'true') {
                return; // User doesn't want to see the cat
            }

            root = document.getElementById('rp-root') as HTMLElement | null;
            inner = document.getElementById('rp-inner') as HTMLElement | null;
            cat = document.getElementById('rp-cat') as HTMLElement | null;
            speech = document.getElementById('rp-speech') as HTMLElement | null;
            eyeL = document.getElementById('rp-eye-l') as HTMLElement | null;
            eyeR = document.getElementById('rp-eye-r') as HTMLElement | null;
            pupilL = document.getElementById('rp-pupil-l') as HTMLElement | null;
            pupilR = document.getElementById('rp-pupil-r') as HTMLElement | null;
            mouth = document.getElementById('rp-mouth') as HTMLElement | null;
            closeBtn = document.getElementById('rp-close') as HTMLElement | null;

            if (!root || !cat || !inner) return;

            // Start fresh
            cleanupCat();
            isVisible = false;
            interacting = false;
            isDragging = false;

            // Generate a position safely
            function safePos() {
                const edge = Math.floor(Math.random() * 4);
                switch (edge) {
                    case 0:
                        return { x: 1, y: 14 + Math.random() * 70 }; // left edge
                    case 1:
                        return { x: 88, y: 14 + Math.random() * 70 }; // right edge
                    case 2:
                        return { x: 8 + Math.random() * 76, y: 10 }; // top edge
                    case 3:
                        return { x: 8 + Math.random() * 76, y: 87 }; // bottom edge
                    default:
                        return { x: 1, y: 50 };
                }
            }

            function teleportTo(x: number, y: number) {
                if (!root) return;
                root.style.transition = 'opacity 0.8s ease';
                root.style.left = `${x}vw`;
                root.style.top = `${y}vh`;
            }

            function walkTo(x: number, y: number) {
                if (!root) return;
                root.style.transition = 'left 2.5s cubic-bezier(.4,0,.2,1), top 2.5s cubic-bezier(.4,0,.2,1), opacity 0.8s ease';
                root.style.left = `${x}vw`;
                root.style.top = `${y}vh`;
            }

            function show() {
                if (!root) return;
                const { x, y } = safePos();
                teleportTo(x, y);
                root.style.opacity = '1';
                isVisible = true;
                setCatAnim('rp-float');
                scheduleWander();
            }

            function hide() {
                if (!root) return;
                root.style.opacity = '0';
                isVisible = false;
                clearTimeout(wanderTimer);
                setCatAnim('');
                appearTimer = window.setTimeout(show, 25000 + Math.random() * 30000); // 25s–55s vanish
            }

            function wander() {
                if (!isVisible || interacting || isDragging) {
                    scheduleWander();
                    return;
                }
                const { x, y } = safePos();
                walkTo(x, y);
                // 20% chance to vanish shortly after arriving at a point
                if (Math.random() < 0.2) {
                    window.setTimeout(
                        () => {
                            if (isVisible) hide();
                        },
                        4000 + Math.random() * 4000
                    );
                } else {
                    scheduleWander();
                }
            }

            function scheduleWander() {
                clearTimeout(wanderTimer);
                wanderTimer = window.setTimeout(wander, 14000 + Math.random() * 18000);
            }

            // Appear very shortly after site loads
            appearTimer = window.setTimeout(show, 4000 + Math.random() * 5000);

            // ── Animation helpers ─────────────────────────────────────
            const animDur: Record<string, number> = {
                'rp-nod': 900,
                'rp-spin': 600,
                'rp-bounce': 1100,
                'rp-wave': 1650,
                'rp-tremble': 800,
                'rp-shy': 1200
            };

            function setCatAnim(name: string) {
                if (!cat) return;
                cat.className = name ? `rp-cat ${name}` : 'rp-cat';
                void cat.offsetWidth; // force reflow
            }

            function playAnim(name: string) {
                setCatAnim(name);
                window.setTimeout(() => setCatAnim('rp-float'), animDur[name] ?? 1000);
            }

            function say(msg: string, duration = 2200) {
                if (!speech) return;
                clearTimeout(speechTimer);
                speech.textContent = msg;
                speech.style.opacity = '1';
                speechTimer = window.setTimeout(() => {
                    if (speech) speech.style.opacity = '0';
                }, duration);
            }

            function blink() {
                if (!eyeL || !eyeR) return;
                eyeL.style.height = '1px';
                eyeR.style.height = '1px';
                window.setTimeout(() => {
                    if (eyeL) eyeL.style.height = '10px';
                    if (eyeR) eyeR.style.height = '10px';
                }, 180);
            }

            function squint(dur = 1800) {
                if (!eyeL || !eyeR) return;
                eyeL.style.height = '2px';
                eyeR.style.height = '2px';
                window.setTimeout(() => {
                    if (eyeL) eyeL.style.height = '10px';
                    if (eyeR) eyeR.style.height = '10px';
                }, dur);
            }

            function bigEyes(dur = 900) {
                if (!eyeL || !eyeR) return;
                eyeL.style.transform = 'scale(1.6)';
                eyeR.style.transform = 'scale(1.6)';
                window.setTimeout(() => {
                    if (eyeL) eyeL.style.transform = 'scale(1)';
                    if (eyeR) eyeR.style.transform = 'scale(1)';
                }, dur);
            }

            function bigSmile(dur = 2000) {
                if (!mouth) return;
                mouth.style.width = '22px';
                mouth.style.height = '10px';
                mouth.style.borderBottomWidth = '2px';
                mouth.style.opacity = '0.7';
                window.setTimeout(() => {
                    if (!mouth) return;
                    mouth.style.width = '';
                    mouth.style.height = '';
                    mouth.style.borderBottomWidth = '';
                    mouth.style.opacity = '';
                }, dur);
            }

            function dash() {
                if (!root) return;
                const { x, y } = safePos();
                root.style.transition = 'left 0.5s cubic-bezier(.4,0,.2,1), top 0.5s cubic-bezier(.4,0,.2,1), opacity 0.8s ease';
                root.style.left = `${x}vw`;
                root.style.top = `${y}vh`;
            }

            // ── Hide Button ───────────────────────────────────────────
            if (closeBtn) {
                closeBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    localStorage.setItem('rp-hidden', 'true');
                    if (root) root.style.opacity = '0';
                    cleanupCat();
                });
            }

            // ── Drag & Drop ───────────────────────────────────────────
            if (inner) {
                let startX = 0,
                    startY = 0;
                let initialLeft = 0,
                    initialTop = 0;

                const startDrag = (e: MouseEvent | TouchEvent) => {
                    if (e.target === closeBtn) return;
                    isDragging = false;
                    const cX = 'touches' in e ? e.touches[0].clientX : (e as MouseEvent).clientX;
                    const cY = 'touches' in e ? e.touches[0].clientY : (e as MouseEvent).clientY;
                    startX = cX;
                    startY = cY;

                    if (root) {
                        const rect = root.getBoundingClientRect();
                        initialLeft = rect.left;
                        initialTop = rect.top;
                        root.style.transition = 'opacity 0.8s ease'; // disable position easing during drag
                    }

                    const moveDrag = (ev: MouseEvent | TouchEvent) => {
                        const mX = 'touches' in ev ? ev.touches[0].clientX : (ev as MouseEvent).clientX;
                        const mY = 'touches' in ev ? ev.touches[0].clientY : (ev as MouseEvent).clientY;

                        const dx = mX - startX;
                        const dy = mY - startY;

                        if (Math.abs(dx) > 5 || Math.abs(dy) > 5) {
                            isDragging = true;
                            if (inner) inner.style.cursor = 'grabbing';
                            if (root) {
                                // Update position (clamped to screen)
                                const vw = ((initialLeft + dx) / window.innerWidth) * 100;
                                const vh = ((initialTop + dy) / window.innerHeight) * 100;
                                root.style.left = `${Math.max(0, Math.min(95, vw))}vw`;
                                root.style.top = `${Math.max(0, Math.min(95, vh))}vh`;
                            }
                        }
                    };

                    const stopDrag = () => {
                        document.removeEventListener('mousemove', moveDrag);
                        document.removeEventListener('mouseup', stopDrag);
                        document.removeEventListener('touchmove', moveDrag);
                        document.removeEventListener('touchend', stopDrag);
                        if (inner) inner.style.cursor = 'grab';

                        // Small delay before drag flag drops to prevent click event
                        setTimeout(() => {
                            isDragging = false;
                        }, 50);
                    };

                    document.addEventListener('mousemove', moveDrag);
                    document.addEventListener('mouseup', stopDrag);
                    document.addEventListener('touchmove', moveDrag, { passive: false });
                    document.addEventListener('touchend', stopDrag);
                };

                inner.addEventListener('mousedown', startDrag);
                inner.addEventListener('touchstart', startDrag, { passive: false });

                // Clicking
                const interactions = [
                    () => {
                        playAnim('rp-nod');
                        say('嗯嗯~');
                    },
                    () => {
                        bigSmile(2000);
                        squint(2000);
                        playAnim('rp-bounce');
                        say('(≧▽≦)');
                    },
                    () => {
                        playAnim('rp-spin');
                        say('(=^・ω・^=)');
                    },
                    () => {
                        playAnim('rp-wave');
                        say('摸摸我~');
                    },
                    () => {
                        bigEyes(900);
                        playAnim('rp-tremble');
                        say('！？');
                    },
                    () => {
                        squint(2500);
                        say('zzZ...');
                    },
                    () => {
                        say('(=ↀωↀ=)✧');
                        window.setTimeout(dash, 300);
                    },
                    () => {
                        playAnim('rp-bounce');
                        say('喵呜!');
                    },
                    () => {
                        blink();
                        playAnim('rp-nod');
                        say('喵~');
                    },
                    () => {
                        bigSmile(1500);
                        say('(=^・^=)');
                    },
                    () => {
                        playAnim('rp-shy');
                        say('害羞...');
                        squint(1200);
                    }
                ];
                let lastIdx = -1;

                inner.addEventListener('click', (e) => {
                    if (interacting || isDragging) return;
                    interacting = true;
                    blink();
                    let idx: number;
                    do {
                        idx = Math.floor(Math.random() * interactions.length);
                    } while (idx === lastIdx && interactions.length > 1);
                    lastIdx = idx;
                    interactions[idx]();
                    window.setTimeout(() => {
                        interacting = false;
                    }, 1600);
                });
            }

            document.addEventListener('mousemove', onMouseMoveHandler);
            document.addEventListener('scroll', onScrollHandler);
        }

        // ── Observers ───────────────────────────────────────────
        function onMouseMoveHandler(e: MouseEvent) {
            if (!isVisible || !pupilL || !pupilR || !inner) return;
            const rect = inner.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const maxM = 2;
            const px = Math.max(-maxM, Math.min(maxM, (e.clientX - cx) / 60));
            const py = Math.max(-maxM, Math.min(maxM, (e.clientY - cy) / 60));
            pupilL.style.transform = `translate(${px}px, ${py}px)`;
            pupilR.style.transform = `translate(${px}px, ${py}px)`;
        }

        function onScrollHandler() {
            if (!isVisible || interacting || isDragging) return;
            const currentScrollY = window.scrollY;
            const delta = Math.abs(currentScrollY - lastScrollY);

            if (delta > 200) {
                // Fast scroll threshold
                clearTimeout(scrollTimer);
                interacting = true;

                // "Scared by fast scroll" reaction
                if (root) root.style.transition = 'opacity 0.8s ease';
                if (cat) cat.className = 'rp-cat rp-spin';
                if (speech) {
                    speech.textContent = '哇哦！喵！！';
                    speech.style.opacity = '1';
                }

                scrollTimer = window.setTimeout(() => {
                    interacting = false;
                    if (cat) cat.className = 'rp-cat rp-float';
                    if (speech) speech.style.opacity = '0';
                }, 1200);

                lastScrollY = currentScrollY;
            } else {
                scrollTimer = window.setTimeout(() => {
                    lastScrollY = window.scrollY;
                }, 50);
            }
        }

        // Support Astro View Transitions and regular loading
        document.addEventListener('astro:page-load', initCat);
        document.addEventListener('astro:before-swap', cleanupCat);

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initCat);
        } else {
            initCat();
        }
    })();
</script>
