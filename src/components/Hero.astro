---
import { Image } from 'astro:assets';
import heroAvatarImg from '../assets/hero.png';
import siteConfig from '../data/site-config';
import DailyQuote from './DailyQuote.astro';
import DateDisplay from './DateDisplay.astro';
import WeatherWidget from './WeatherWidget.astro';

const hero = siteConfig.hero;
const weatherCity = hero?.weatherCity || 'Shenzhen';
---

{
    hero && (
        <section class="w-full mb-28 sm:mb-40 flex flex-col gap-20 sm:gap-28 mt-8 sm:mt-12">
            {/* Profile Section */}
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 sm:gap-12 text-center sm:text-left">
                {hero.avatar?.src && (
                    <Image
                        class="w-28 h-28 sm:w-36 sm:h-36 rounded-full object-cover shrink-0 shadow-lg border-4 border-transparent dark:border-main/5 transition-transform hover:scale-105 duration-700"
                        src={heroAvatarImg}
                        alt={hero.avatar.alt || ''}
                        width={144}
                        height={144}
                        loading="eager"
                        format="webp"
                    />
                )}
                <div class="flex flex-col gap-4 mt-2 sm:mt-6">
                    <div class="flex flex-wrap items-center justify-center sm:justify-start gap-4 sm:gap-6">
                        {hero.name && <h1 class="text-4xl sm:text-5xl font-serif font-bold leading-tight tracking-tight mt-1">{hero.name}</h1>}
                        <WeatherWidget weatherCity={weatherCity} />
                    </div>

                    {hero.bio && <p class="text-base sm:text-xl leading-relaxed opacity-80 max-w-2xl mt-2">{hero.bio}</p>}
                    <DateDisplay />
                </div>
            </div>

            <DailyQuote />
        </section>
    )
}
