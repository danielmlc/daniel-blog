---
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../icons/ArrowRight.astro';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description, demoUrl, repoUrl } = project.data;
const TitleTag = headingLevel;
---

<div class:list={['flex justify-between items-start gap-8 group pb-6 border-b border-dashed border-main/20 hover:border-main/50 transition-colors', className]}>
    <div class="grow">
        <a href={`/projects/${project.id}/`}>
            <TitleTag
                class="text-xl leading-tight font-serif font-medium group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors sm:text-2xl"
            >
                {title}
            </TitleTag>
        </a>
        {description && <div class="mt-2 text-sm text-main/80 leading-relaxed max-w-2xl">{description}</div>}
        {
            (demoUrl || repoUrl) && (
                <div class="mt-4 flex flex-wrap gap-4 text-sm font-serif">
                    {demoUrl && (
                        <a
                            class="border-b border-dashed border-main/40 hover:border-main transition-colors pb-0.5"
                            href={demoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            在线演示 ↗
                        </a>
                    )}
                    {repoUrl && (
                        <a
                            class="border-b border-dashed border-main/40 hover:border-main transition-colors pb-0.5"
                            href={repoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            源码仓库 ↗
                        </a>
                    )}
                </div>
            )
        }
    </div>
    <a
        class="hidden font-serif opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:gap-1 sm:items-center sm:shrink-0 text-main/70"
        href={`/projects/${project.id}/`}
    >
        查看详情 <ArrowRight class="fill-current w-4 h-4 ml-1" />
    </a>
</div>
