---
import BaseLayout from '../layouts/BaseLayout.astro';
import Subscribe from '../components/Subscribe.astro';
---

<BaseLayout title="邮箱订阅" description="订阅博客更新，第一时间获取最新文章与动态。" showHeader={false}>
    <div class="mb-12 sm:mb-16">
        <h1 class="text-3xl leading-tight font-serif font-bold sm:text-4xl text-main">邮箱订阅</h1>
        <p class="mt-3 text-sm text-main/50">订阅后，新文章发布时将通过邮件通知您。</p>
    </div>
    <Subscribe />
    <div class="mt-12 space-y-2 text-sm text-main/40">
        <p>您也可以通过 <a href="/rss.xml" class="underline hover:text-main/70 transition-colors">RSS</a> 订阅本站内容。</p>
        <p>每封邮件底部都包含退订链接，您可以随时取消订阅。</p>
    </div>
</BaseLayout>
