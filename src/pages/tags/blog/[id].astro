---
import { type CollectionEntry, getCollection } from 'astro:content';
import PostPreview from '../../../components/PostPreview.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllTags, getItemsByTag, sortItemsByDateDesc } from '../../../utils/data-utils';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    const tags = getAllTags(posts);
    return tags.map((tag) => ({
        params: { id: tag.id },
        props: { tag, posts: getItemsByTag(posts, tag.id).sort(sortItemsByDateDesc) }
    }));
}

type Props = { tag: { name: string; id: string }; posts: CollectionEntry<'blog'>[] };
const { tag, posts } = Astro.props;
---

<BaseLayout title={`文章标签：${tag.name}`} description={`浏览所有标签为「${tag.name}」的博客文章`} showHeader={false}>
    <div class="mb-12 sm:mb-16">
        <div class="text-sm font-medium text-main/50 mb-4 tracking-widest uppercase flex items-center gap-2">
            <a href="/tags" class="hover:text-main/80 transition-colors">分类标签</a>
            <span class="w-8 h-[1px] bg-main/20" />
            <span>文章</span>
        </div>
        <h1 class="text-3xl leading-tight font-serif font-bold sm:text-4xl text-main">{tag.name}</h1>
        <p class="mt-3 text-sm text-main/50">共 {posts.length} 篇文章</p>
    </div>
    {posts.map((post) => <PostPreview post={post} class="mb-10 sm:mb-12" />)}

</BaseLayout>
